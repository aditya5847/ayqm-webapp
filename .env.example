AYQM_DATABASE_PATH=data/ayqm.duckdb
AYQM_UPLOAD_ROOT=data/uploads
AYQM_EPISODE_ROOT=data/episodes
AYQM_WHISPER_MODEL=base
AYQM_WHISPER_DEVICE=cpu
AYQM_WHISPER_COMPUTE_TYPE=int8
AYQM_WHISPER_BATCH_SIZE=16
AYQM_GEMINI_MODEL=gemini-3.1-flash-lite
AYQM_FFMPEG_PATH=ffmpeg

# Required for trivia extraction.
GEMINI_API_KEY=
# GOOGLE_API_KEY is also supported by ayqm-transcribe as a fallback.

# Required only when diarization is enabled.
HF_TOKEN=
